NEXT_PUBLIC_SITE_URL=https://brainrotkit.com
NEXT_PUBLIC_ALLOW_INDEXING=false
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# Google-only authentication.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AUTH_SECRET=
ADMIN_EMAILS=

# Creem billing. Production deployments use the live API; local development may opt into test mode.
CREEM_API_KEY=
CREEM_WEBHOOK_SECRET=
CREEM_TEST_MODE=false
CREEM_PRODUCT_CREATOR_MONTHLY=
CREEM_PRODUCT_CREATOR_ANNUAL=
CREEM_PRODUCT_PRO_MONTHLY=
CREEM_PRODUCT_PRO_ANNUAL=
CREEM_PRODUCT_CREDITS=

# Private file storage. Keep the service-role key server-side only.
SUPABASE_URL=
SUPABASE_STORAGE_BUCKET=
SUPABASE_SERVICE_ROLE_KEY=

# Kie AI. Both values are server-only Cloudflare secrets in production.
KIE_API_KEY=
KIE_WEBHOOK_SECRET=
