{
  "name": "brainrotkit",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "build:cloudflare": "opennextjs-cloudflare build && node scripts/copy-static-pages.mjs",
    "dev": "next dev",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test:timeline": "node scripts/validate-audio-timeline.mjs",
    "test:script": "node scripts/validate-brainrot-script.mjs",
    "seo:check": "node scripts/validate-seo-content.mjs",
    "frontend:audit": "node scripts/audit-frontend.mjs",
    "preview": "npm run build:cloudflare && opennextjs-cloudflare preview",
    "deploy": "npm run build:cloudflare && opennextjs-cloudflare deploy",
    "upload": "npm run build:cloudflare && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote"
  },
  "dependencies": {
    "@imgly/background-removal": "^1.7.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-select": "^2.3.4",
    "lucide-react": "^0.468.0",
    "mediabunny": "^1.50.9",
    "next": "^16.2.10",
    "next-auth": "^5.0.0-beta.31",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@tailwindcss/postcss": "^4.1.14",
    "@types/node": "^22.18.6",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "eslint": "^9.36.0",
    "eslint-config-next": "^16.2.10",
    "tailwindcss": "^4.1.14",
    "typescript": "^5.9.2",
    "wrangler": "^4.111.0"
  },
  "overrides": {
    "postcss": "8.5.19"
  }
}
